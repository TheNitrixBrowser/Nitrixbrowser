{
  "name": "Nitrix",
  "version": "1.3.2",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.nitrix.browser",
    "productName": "Nitrix",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "**/*",
      "!dane_przegladarki/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "TheNitrixBrowser",
      "repo": "autoaktualizacjenitrix",
      "private": false
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}